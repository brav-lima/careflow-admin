{
  "name": "careflow-admin-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "dotenvx run -f .env.dev -- nest start --watch",
    "start:debug": "dotenvx run -f .env.dev -- nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "dotenvx run -f .env.dev -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenvx run -f .env.prod -- prisma migrate deploy",
    "prisma:seed": "dotenvx run -f .env.dev -- ts-node prisma/seed.ts",
    "prisma:studio": "dotenvx run -f .env.dev -- prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.0.0",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/testing": "^11.1.18",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
